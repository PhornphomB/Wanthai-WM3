<configuration>
  <configSections>
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
    <!-- For more information on Entity Framework configuration, visit http://go.microsoft.com/fwlink/?LinkID=237468 -->
  </configSections>
  <connectionStrings>
    <add name="WMSEntities" connectionString="metadata=res://*/DataSource.csdl|res://*/DataSource.ssdl|res://*/DataSource.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=10.10.60.89;initial catalog=WM3;user id=sa;password=Local@dmin;MultipleActiveResultSets=True;App=EntityFramework&quot;" providerName="System.Data.EntityClient" />
    <!--<add name="WMSEntities" connectionString="metadata=res://*/DataSource.csdl|res://*/DataSource.ssdl|res://*/DataSource.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=10.10.60.144;initial catalog=WM3;user id=sa;password=Local@dmin;MultipleActiveResultSets=True;App=EntityFramework&quot;" providerName="System.Data.EntityClient" />-->
    <add name="SecurityM_Entities" connectionString="metadata=res://*/SecuritySource.csdl|res://*/SecuritySource.ssdl|res://*/SecuritySource.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=10.10.60.89;initial catalog=WM3_Security;persist security info=True;user id=sa;password=Local@dmin;multipleactiveresultsets=True;application name=EntityFramework&quot;" providerName="System.Data.EntityClient" />
  </connectionStrings>
  <entityFramework>
    <defaultConnectionFactory type="System.Data.Entity.Infrastructure.LocalDbConnectionFactory, EntityFramework">
      <parameters>
        <parameter value="mssqllocaldb" />
      </parameters>
    </defaultConnectionFactory>
    <providers>
      <provider invariantName="System.Data.SqlClient" type="System.Data.Entity.SqlServer.SqlProviderServices, EntityFramework.SqlServer" />
    </providers>
  </entityFramework>
  <appSettings>
    <add key="WEB_NAME" value="ALL NEW WMS" />
    <add key="DateFormat" value="dd/MM/yyyy" />
    <add key="TimeFormat" value="HH:mm:ss" />
    <add key="UICulture" value="en-US" />
    <add key="GridFontStyle" value="Segoe UI" />
    <add key="GridFontSize" value="12" />
    <add key="GridDataMaxLength" value="180" />
    <add key="APP_ID" value="CC3D76CA-71B9-47CB-A933-4B1F1F489AF0" />
    <add key="PLATFORM" value="Web" />
    <add key="WEB_SECURE_API_URL" value="http://10.10.60.89/WM3_Security/" />
    <add key="WEB_SECURE_API_FUNC_LOGIN" value="Secure/Login" />
    <add key="WEB_SECURE_API_FUNC_LOGOUT" value="Secure/Logout" />
    <add key="WEB_SECURE_API_FUNC_GETMENU" value="Secure/GetMenu" />
    <add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />
    <add key="ReportUrl" value="http://10.10.60.89/WM3_Report/CrystalReport.aspx?_app_AppName=WMS_Report" />
    <add key="ReportUrlRDL" value="http://10.10.60.89/WM3_Report/Reporting.aspx?_app_AppName=WMS_Report" />
    <add key="FolderImages" value="~/_Upload/" />
    <add key="FolderTemp" value="~/_Temp/" />
    <add key="FolderRDL" value="~/RDL/" />
	<add key="LocalDatetimeFormat" value="M/d/yyyy h:mm:ss tt" />
  </appSettings>
  <!--
    For a description of web.config changes see http://go.microsoft.com/fwlink/?LinkId=235367.

    The following attributes can be set on the <httpRuntime> tag.
      <system.Web>
        <httpRuntime targetFramework="4.6.1" />
      </system.Web>
  -->
  <system.web>
    <compilation debug="true" targetFramework="4.6.1">
      <buildProviders>
        <add extension=".rdlc" type="Microsoft.Reporting.RdlBuildProvider, Microsoft.ReportViewer.WebForms, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845DCD8080CC91" />
      </buildProviders>
      <assemblies>
        <!--<add assembly="log4net, Version=1.2.10.0, Culture=neutral, PublicKeyToken=692FBEA5521E1304" />-->
        <!--<add assembly="Microsoft.ReportViewer.Common, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845DCD8080CC91" />
        <add assembly="Microsoft.ReportViewer.WebForms, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845DCD8080CC91" />-->
      </assemblies>
    </compilation>
    <httpRuntime targetFramework="4.5.2" executionTimeout="600" maxRequestLength="102400" />
    <httpHandlers>
      <add path="Reserved.ReportViewerWebControl.axd" verb="*" type="Microsoft.Reporting.WebForms.HttpHandler, Microsoft.ReportViewer.WebForms, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845DCD8080CC91" validate="false" />
    </httpHandlers>
    <customErrors mode="RemoteOnly" defaultRedirect="~/Default.aspx" />
    <!--Handles session time out-->
    <sessionState timeout="60" mode="InProc" cookieless="false" />
    <globalization culture="en-US" enableClientBasedCulture="true" fileEncoding="windows-874" requestEncoding="utf-8" responseEncoding="utf-8" uiCulture="en-US" />
    <pages controlRenderingCompatibilityVersion="4.0" clientIDMode="AutoID" enableEventValidation="false" theme="DefaultTheme">
      <controls>
        <add tagPrefix="customControls" namespace="CustomControls" assembly="CustomControls" />
        <add tagPrefix="customControls" namespace="_UControls.DataPager" assembly="WMS_NEW" />
        <add tagPrefix="ucControls" namespace="_UControls.EntityExtend" assembly="WMS_NEW" />
        <add tagPrefix="ucControls" namespace="_UControls.PanelCustom" assembly="WMS_NEW" />
        <add tagPrefix="ucControls" src="~/_UControls/GridViewExt.ascx" tagName="GridExt" />
        <add tagPrefix="ucControls" src="~/_UControls/GridColumnExt.ascx" tagName="GridColumnExt" />
        <add tagPrefix="ucControls" src="~/_UControls/PanelPopup.ascx" tagName="PanelPopup" />
        <add tagPrefix="ucControls" src="~/_UControls/PanelPopupEntity.ascx" tagName="PanelPopupEntity" />
        <add tagPrefix="ucControls" src="~/_UControls/PanelTab.ascx" tagName="PanelTab" />
        <add tagPrefix="ucControls" src="~/_UControls/LabelExt.ascx" tagName="LabelExt" />
        <add tagPrefix="ucControls" src="~/_UControls/ButtonExt.ascx" tagName="ButtonExt" />
        <add tagPrefix="ucControls" src="~/_UControls/InputControls/InputHidden.ascx" tagName="InputHidden" />
        <add tagPrefix="ucControls" src="~/_UControls/InputControls/InputTextDate.ascx" tagName="InputTextDate" />
        <add tagPrefix="ucControls" src="~/_UControls/InputControls/InputTextBox.ascx" tagName="InputTextBox" />
        <add tagPrefix="ucControls" src="~/_UControls/InputControls/InputTextInteger.ascx" tagName="InputTextInteger" />
        <add tagPrefix="ucControls" src="~/_UControls/InputControls/InputTextNumber.ascx" tagName="InputTextNumber" />
        <add tagPrefix="ucControls" src="~/_UControls/InputControls/InputDropDown.ascx" tagName="InputDropDown" />
        <add tagPrefix="ucControls" src="~/_UControls/InputControls/InputDropDownHD.ascx" tagName="InputDropDownHD" />
        <add tagPrefix="ucControls" src="~/_UControls/InputControls/InputCheckBox.ascx" tagName="InputCheckBox" />
        <add tagPrefix="ucControls" src="~/_UControls/UploadFileEx.ascx" tagName="UploadEx" />
      </controls>
    </pages>
  </system.web>
  <system.webServer>
    <directoryBrowse enabled="true" />
    <validation validateIntegratedModeConfiguration="false" />
    <modules runAllManagedModulesForAllRequests="true" />
    <handlers>
      <add name="ReportViewerWebControlHandler" verb="*" path="Reserved.ReportViewerWebControl.axd" preCondition="integratedMode" type="Microsoft.Reporting.WebForms.HttpHandler, Microsoft.ReportViewer.WebForms, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845DCD8080CC91" />
    </handlers>
  </system.webServer>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="EntityFramework" publicKeyToken="b77a5c561934e089" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-5.0.0.0" newVersion="5.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Text.Encoding.CodePages" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-6.0.0.0" newVersion="6.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Runtime.CompilerServices.Unsafe" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-6.0.0.0" newVersion="6.0.0.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
  <system.codedom>
    <compilers>
      <compiler language="c#;cs;csharp" extension=".cs" type="Microsoft.CodeDom.Providers.DotNetCompilerPlatform.CSharpCodeProvider, Microsoft.CodeDom.Providers.DotNetCompilerPlatform, Version=1.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" warningLevel="4" compilerOptions="/langversion:6 /nowarn:1659;1699;1701" />
      <compiler language="vb;vbs;visualbasic;vbscript" extension=".vb" type="Microsoft.CodeDom.Providers.DotNetCompilerPlatform.VBCodeProvider, Microsoft.CodeDom.Providers.DotNetCompilerPlatform, Version=1.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" warningLevel="4" compilerOptions="/langversion:14 /nowarn:41008 /define:_MYTYPE=\&quot;Web\&quot; /optionInfer+" />
    </compilers>
  </system.codedom>
</configuration>